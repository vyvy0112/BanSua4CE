@model BanSua4CE.Data.SanPham

@{
    ViewData["Title"] = "Edit";
}


<h4>Sửa Thông Tin Sản Phẩm</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdSp" />
            <div class="form-group">
                <label  class="control-label"> Tên Sản Phẩm</label>
                <input asp-for="TenSp" class="form-control" />
                <span asp-validation-for="TenSp" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Đơn Giá</label>
                <input asp-for="DonGia" class="form-control" />
                <span asp-validation-for="DonGia" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Mô Tả</label>
                <input asp-for="MoTa" class="form-control" />
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Xuất Xứ</label>
                <input asp-for="XuatXu" class="form-control" />
                <span asp-validation-for="XuatXu" class="text-danger"></span>
            </div>
             <div class="form-item">
                 <label class="form-label my-3" for="hinhanh">Hình Ảnh<sup>*</sup></label>
                 <input type="file" name="hinhanh" class="form-control" required />
             </div> 
           
            <div class="form-group">
                <label class="control-label">Trạng Thái</label>
                <input asp-for="Status" class="form-control" />
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdDanhMuc" class="control-label"></label>
                <select asp-for="IdDanhMuc" class="form-control" asp-items="ViewBag.IdDanhMuc"></select>
                <span asp-validation-for="IdDanhMuc" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-sm btn-warning">Back to List</a>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
