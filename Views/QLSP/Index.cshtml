@model IEnumerable<BanSua4CE.Data.SanPham>

@{
    ViewData["Title"] = "Index";
}

<h1>Danh Sách Các Sản Phẩm</h1>

<p>
    <a asp-action="Create" asp-controller="QLSP" class="btn btn-sm btn-primary">Thêm Sản Phẩm</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                <label>Mã</label>
            </th>
            <th>
                <label>Tên SP</label>
            </th>
            <th>
                <label>Giá</label>
            </th>
            <th>
                <label>Mô Tả</label>
            </th>
            <th>
                <label>Xuất Xứ</label>
            </th>
            <th>
                <label>Hình Ảnh</label>
            </th>
          
            <th>
                @Html.DisplayNameFor(model => model.IdDanhMuc)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IdSp)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TenSp)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DonGia)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MoTa)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.XuatXu)
            </td>
            <td>
                 <img src="~/hinhanh/@item.HinhAnh" width="80px"/>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdDanhMuc)
            </td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-controller="QLSP" asp-route-id="@item.IdSp" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-controller="QLSP" asp-route-id="@item.IdSp" class="btn btn-sm btn-primary">Delete</a>
                        <a asp-action="Details" asp-controller="QLSP" asp-route-id="@item.IdSp" class="btn btn-sm btn-primary">Details</a>
                    </div>
                </td>



        </tr>
}
    </tbody>
</table>
